      "VpcConfig": {"VpcId": "vpc-0prod1234", "SubnetIds": ["subnet-0private-2a", "subnet-0private-2b"], "SecurityGroupIds": ["sg-0lambda55555"]}
    },
    {
      "FunctionName": "db-rotation",
      "FunctionArn": "arn:aws:lambda:us-east-2:123456789012:function:db-rotation",
      "Runtime": "python3.12", "Handler": "rotation.handler",
      "Role": "arn:aws:iam::123456789012:role/lambda-rotation-role",
      "Timeout": 60, "MemorySize": 128,
      "VpcConfig": {"VpcId": "vpc-0prod1234", "SubnetIds": ["subnet-0private-2a", "subnet-0private-2b"], "SecurityGroupIds": ["sg-0lambda55555"]}
    }
  ]
}
