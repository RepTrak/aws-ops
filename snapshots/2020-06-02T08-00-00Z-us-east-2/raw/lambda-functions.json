{
  "Functions": [
    {
      "FunctionName": "event-processor",
      "FunctionArn": "arn:aws:lambda:us-east-2:123456789012:function:event-processor",
      "Runtime": "python3.12", "Handler": "handler.process",
      "Role": "arn:aws:iam::123456789012:role/lambda-event-processor-role",
