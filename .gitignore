# ─── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ─── Editors ──────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ─── Environment & secrets ────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ─── Navigator — build artifacts ──────────────────────────────────────────────
navigator/node_modules/
navigator/dist/
navigator/.vite/

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*

# ─── Snapshot data ────────────────────────────────────────────────────────────
# Snapshots generated by export-infra-snapshot.sh are environment-specific and
# can be very large. They are excluded from the repo.
#
# Only the two generic demo snapshots and latest.json (pointing at the newer demo)
# are committed, so that the navigator works out of the box without running a real
# export. latest.json is kept in .gitignore so that running a real export (which
# updates latest.json to the new snapshot folder) doesn't accidentally get staged.
snapshots/*
!snapshots/2020-06-02T08-00-00Z-us-east-2/
!snapshots/2020-06-03T10-00-00Z-us-east-2/

# Temporary stderr files written by safe_aws_json during snapshot export
*.stderr
