# ─── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ─── Editors ──────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ─── Environment & secrets ────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ─── Navigator — build artifacts ──────────────────────────────────────────────
navigator/node_modules/
navigator/dist/
navigator/.vite/

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*

# ─── Snapshot data ────────────────────────────────────────────────────────────
# Snapshots generated by export-infra-snapshot.sh are environment-specific and
# can be very large. They are excluded from the repo.
#
# Only the two generic demo snapshots are committed, together with latest.json,
# so that the navigator works out of the box without running a real export.
snapshots/*
!snapshots/latest.json
!snapshots/2020-06-02T08-00-00Z-us-east-2/
!snapshots/2020-06-03T10-00-00Z-us-east-2/

# Temporary stderr files written by safe_aws_json during snapshot export
*.stderr
